{
  "expo": {
    "name": "GPSBridge",
    "slug": "gps-bridge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gpsbridge",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.gpsbridge",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "geo"
            }
          ]
        },
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "http",
              "host": "maps.google.com"
            },
            {
              "scheme": "https",
              "host": "maps.google.com"
            },
            {
              "scheme": "http",
              "host": "*google.com",
              "pathPrefix": "/maps"
            },
            {
              "scheme": "https",
              "host": "*google.com",
              "pathPrefix": "/maps"
            },
            {
              "scheme": "http",
              "host": "maps.app.goo.gl"
            },
            {
              "scheme": "https",
              "host": "maps.app.goo.gl"
            },
            {
              "scheme": "http",
              "host": "goo.gl"
            },
            {
              "scheme": "https",
              "host": "goo.gl"
            }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
